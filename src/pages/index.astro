---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tera Axial | Alexandre Barbosa" description="Psicanálise Clínica no Rio de Janeiro">
	<main style="background-color: #1a1d23; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; font-family: sans-serif; color: white; text-align: center; padding: 20px;">
		<p style="text-transform: uppercase; letter-spacing: 5px; font-size: 12px; opacity: 0.6; margin-bottom: 40px;">
			Tera Axial | Alexandre Barbosa
		</p>
		<h1 style="font-size: 48px; font-style: italic; margin-bottom: 20px;">Em Breve</h1>
		<p style="max-width: 400px; opacity: 0.8; line-height: 1.6;">
			Um novo eixo na psicanálise clínica. O site oficial está sendo preparado.
		</p>
	</main>
</Layout>
